<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox spacing="0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.wechat.client.ChatController" prefWidth="900.0" prefHeight="650.0" styleClass="root">
    
    <!-- Sidebar: Liste des utilisateurs -->
    <VBox prefWidth="250.0" styleClass="liste-utilisateurs">
        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #f0f2f5; -fx-padding: 15;">
            <Label fx:id="monNomLabel" style="-fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Deconnexion" onAction="#gererDeconnexion" style="-fx-background-color: #e9edef; -fx-text-fill: black; -fx-font-size: 11px;" />
        </HBox>
        <ListView fx:id="utilisateursListView" VBox.vgrow="ALWAYS" />
    </VBox>

    <!-- Zone de Chat -->
    <VBox HBox.hgrow="ALWAYS" styleClass="chat-container">
        <!-- Header de la conversation -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #f0f2f5; -fx-padding: 10;">
            <Label fx:id="destinataireLabel" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Sélectionnez un contact" />
        </HBox>

        <!-- Messages -->
        <ScrollPane fx:id="scrollPane" VBox.vgrow="ALWAYS" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #efe7de;">
            <VBox fx:id="messagesContainer" spacing="10.0">
                <padding>
                    <Insets bottom="10.0" left="15.0" right="15.0" top="10.0"/>
                </padding>
            </VBox>
        </ScrollPane>

        <!-- Input -->
        <HBox spacing="10.0" style="-fx-background-color: #f0f2f5; -fx-padding: 10;">
            <TextField fx:id="messageField" HBox.hgrow="ALWAYS" promptText="Écrivez un message..." onAction="#envoyerMessage" />
            <Button text="Envoyer" onAction="#envoyerMessage" />
        </HBox>
    </VBox>
</HBox>
